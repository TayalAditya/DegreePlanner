generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                @id @default(cuid())
  email                    String                @unique
  name                     String?
  image                    String?
  emailVerified            DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  isApproved               Boolean               @default(false)
  role                     UserRole              @default(STUDENT)
  enrollmentId             String?               @unique
  department               String?
  branch                   String?
  previousBranch           String?
  batch                    Int?
  doingMTP                 Boolean               @default(true)
  doingISTP                Boolean               @default(true)
  totalPassFailCredits     Int                   @default(0)
  passFailPerSemester      Int                   @default(0)
  doingMTP2                Boolean               @default(true)
  shareToken               String?               @unique
  isProfileShared          Boolean               @default(false)
  accounts                 Account[]
  announcements            Announcement[]
  enrollments              CourseEnrollment[]
  courseSuggestions        CourseSuggestion[]
  documents                Document[]
  notifications            Notification[]
  preRegistrationPlans     PreRegistrationPlan[]
  sessions                 Session[]
  supportTickets           SupportTicket[]
  approvedTimetableEntries TimetableEntry[]      @relation("TimetableApprovedBy")
  createdTimetableEntries  TimetableEntry[]      @relation("TimetableCreatedBy")
  updatedTimetableEntries  TimetableEntry[]      @relation("TimetableUpdatedBy")
  programs                 UserProgram[]

  @@index([email])
  @@index([enrollmentId])
  @@index([branch])
  @@index([shareToken])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Program {
  id                   String          @id @default(cuid())
  name                 String
  code                 String          @unique
  type                 ProgramType
  department           String
  totalCreditsRequired Int
  description          String?
  icCredits            Int             @default(0)
  dcCredits            Int             @default(0)
  deCredits            Int             @default(0)
  feCredits            Int             @default(0)
  mtpIstpCredits       Int             @default(0)
  minCreditsForMtp     Int?
  minSemesterForMtp    Int?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  courses              ProgramCourse[]
  userPrograms         UserProgram[]

  @@index([code])
  @@index([type])
}

model UserProgram {
  id            String        @id @default(cuid())
  userId        String
  programId     String
  programType   ProgramType
  isPrimary     Boolean       @default(false)
  startSemester Int
  status        ProgramStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  program       Program       @relation(fields: [programId], references: [id])
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([userId])
}

model Course {
  id                 String                @id @default(cuid())
  code               String                @unique
  name               String
  credits            Float
  department         String
  level              Int
  description        String?
  offeredInFall      Boolean               @default(false)
  offeredInSpring    Boolean               @default(false)
  offeredInSummer    Boolean               @default(false)
  isPassFailEligible Boolean               @default(false)
  isBranchSpecific   Boolean               @default(false)
  requiredBranches   String[]
  requiredSemester   Int?
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  ltpc               String?
  branchMappings     CourseBranchMapping[]
  enrollments        CourseEnrollment[]
  equivalents        CourseEquivalent[]    @relation("CourseEquivalents")
  equivalentFor      CourseEquivalent[]    @relation("EquivalentFor")
  offerings          CourseOffering[]
  prerequisites      CoursePrerequisite[]  @relation("CoursePrerequisites")
  prerequisiteFor    CoursePrerequisite[]  @relation("PrerequisiteFor")
  courseSuggestions  CourseSuggestion[]
  programCourses     ProgramCourse[]
  timetableEntries   TimetableEntry[]

  @@index([code])
  @@index([department])
}

model CourseEquivalent {
  id           String @id @default(cuid())
  courseId     String
  equivalentId String
  course       Course @relation("CourseEquivalents", fields: [courseId], references: [id], onDelete: Cascade)
  equivalent   Course @relation("EquivalentFor", fields: [equivalentId], references: [id], onDelete: Cascade)

  @@unique([courseId, equivalentId])
  @@index([courseId])
  @@index([equivalentId])
}

model CoursePrerequisite {
  id             String @id @default(cuid())
  courseId       String
  prerequisiteId String
  course         Course @relation("CoursePrerequisites", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite   Course @relation("PrerequisiteFor", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([courseId, prerequisiteId])
}

model ProgramCourse {
  id         String     @id @default(cuid())
  programId  String
  courseId   String
  courseType CourseType
  isRequired Boolean    @default(false)
  semester   Int?
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  program    Program    @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, courseId])
  @@index([programId])
}

model CourseBranchMapping {
  id             String              @id @default(cuid())
  courseId       String
  branch         String
  courseCategory CourseCategoryType
  isRequired     Boolean             @default(false)
  semester       Int?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  splitAmount    Float?
  splitCategory  CourseCategoryType?
  batch          String              @default("")
  course         Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, branch, batch])
  @@index([courseId])
  @@index([branch])
  @@index([batch])
  @@index([courseCategory])
}

model CourseSuggestion {
  id                String    @id @default(cuid())
  userId            String
  courseId          String
  suggestedCategory String
  currentCategory   String
  reason            String?
  status            String    @default("PENDING")
  reviewedBy        String?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  enrollmentId      String?
  semester          Int?
  term              Term?
  year              Int?
  course            Course    @relation(fields: [courseId], references: [id])
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model CourseEnrollment {
  id              String           @id @default(cuid())
  userId          String
  courseId        String
  semester        Int
  year            Int
  term            Term
  courseType      CourseType
  programId       String?
  grade           String?
  status          EnrollmentStatus @default(IN_PROGRESS)
  isPassFail      Boolean          @default(false)
  passFailCredits Int              @default(0)
  isInternship    Boolean          @default(false)
  internshipType  InternshipType?
  internshipDays  Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  course          Course           @relation(fields: [courseId], references: [id])
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, semester, year, term])
  @@index([userId])
  @@index([semester])
  @@index([isPassFail])
  @@index([isInternship])
}

model ApprovedUser {
  id              String   @id @default(cuid())
  email           String   @unique
  enrollmentId    String?  @unique
  name            String?
  department      String?
  branch          String?
  batch           Int?
  allowedPrograms String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([enrollmentId])
  @@index([branch])
}

model TimetableEntry {
  id            String    @id @default(cuid())
  courseId      String?
  semester      Int
  year          Int
  term          Term
  dayOfWeek     DayOfWeek
  startTime     String
  endTime       String
  venue         String?
  roomNumber    String?
  building      String?
  classType     ClassType @default(LECTURE)
  instructor    String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?
  slot          String?
  updatedById   String?
  approvedAt    DateTime?
  approvedById  String?
  isApproved    Boolean   @default(false)
  googleEventId String?
  approvedBy    User?     @relation("TimetableApprovedBy", fields: [approvedById], references: [id])
  course        Course?   @relation(fields: [courseId], references: [id], onDelete: Restrict)
  createdBy     User?     @relation("TimetableCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?     @relation("TimetableUpdatedBy", fields: [updatedById], references: [id])

  @@index([courseId])
  @@index([semester])
  @@index([dayOfWeek])
  @@index([term, year])
  @@index([createdById])
  @@index([updatedById])
  @@index([isApproved])
  @@index([approvedById])
}

model Venue {
  id         String    @id @default(cuid())
  name       String
  code       String?   @unique
  building   String?
  floor      String?
  capacity   Int?
  type       VenueType @default(CLASSROOM)
  facilities String[]
  isActive   Boolean   @default(true)
  isCustom   Boolean   @default(false)
  isPublic   Boolean   @default(true)
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([code])
  @@index([building])
  @@index([type])
  @@index([isActive])
}

model SupportTicket {
  id          String                    @id @default(cuid())
  userId      String
  type        SupportTicketType
  subject     String
  message     String
  pageUrl     String?
  status      SupportTicketStatus       @default(OPEN)
  adminNote   String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments SupportTicketAttachment[]

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model SupportTicketAttachment {
  id        String        @id @default(cuid())
  ticketId  String
  fileName  String
  mimeType  String
  fileSize  Int
  dataUrl   String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Document {
  id          String           @id @default(cuid())
  userId      String
  title       String
  description String?
  category    DocumentCategory
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  mimeType    String?
  isPublic    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  isActive  Boolean  @default(true)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])

  @@index([isActive, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  isRead    Boolean  @default(false)
  ticketId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model CourseOffering {
  id               String              @id @default(cuid())
  courseId         String?
  courseCode       String
  courseName       String
  instructor       String?
  school           String?
  branches         String[]
  eligibleSems     Int[]
  slots            String?
  ltpc             String?
  credits          Float
  categoryOverride CourseCategoryType?
  curriculumLink   String?
  offeringSemester Int
  offeringYear     Int
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  instructorEmail  String?
  compulsorySem    Int?
  course           Course?             @relation(fields: [courseId], references: [id])

  @@unique([courseCode, offeringSemester, offeringYear])
  @@index([offeringSemester, offeringYear])
  @@index([courseId])
}

model PreRegistrationPlan {
  id               String   @id @default(cuid())
  userId           String
  offeringSemester Int
  offeringYear     Int
  selectedIds      String[]
  savedAt          DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, offeringSemester, offeringYear])
  @@index([offeringSemester, offeringYear])
}

model LoginAttempt {
  id           String   @id @default(cuid())
  email        String
  enrollmentId String?
  name         String?
  outcome      String
  reason       String?
  batch        Int?
  branch       String?
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([outcome, createdAt])
  @@index([createdAt])
}

enum UserRole {
  STUDENT
  ADMIN
}

enum ProgramType {
  MAJOR
  MINOR
  DOUBLE_MAJOR
}

enum ProgramStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum CourseType {
  CORE
  DE
  PE
  FREE_ELECTIVE
  MTP
  ISTP
}

enum CourseCategoryType {
  IC
  IC_BASKET
  DC
  DE
  FE
  HSS
  IKS
  MTP
  ISTP
  INTERNSHIP
  BACKLOG
  NA
}

enum InternshipType {
  REMOTE
  ONSITE
}

enum Term {
  FALL
  SPRING
  SUMMER
}

enum EnrollmentStatus {
  IN_PROGRESS
  COMPLETED
  DROPPED
  FAILED
  AUDIT
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ClassType {
  LECTURE
  LAB
  TUTORIAL
  SEMINAR
  WORKSHOP
  TA_DUTY
}

enum VenueType {
  CLASSROOM
  LAB
  LECTURE_HALL
  TUTORIAL_ROOM
  SEMINAR_ROOM
  LIBRARY
  AUDITORIUM
  ONLINE
  OTHER
}

enum SupportTicketType {
  CONTACT
  SUGGESTION
  ISSUE
  FEEDBACK
}

enum SupportTicketStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum DocumentCategory {
  FORMS
  PROCEDURES
  GUIDES
  CERTIFICATES
  TRANSCRIPTS
  OTHER
}
